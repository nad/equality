------------------------------------------------------------------------
-- Cyclic groups

-- The property of being generated by an element.

Generated-by : (G : Group g) Рєњ Group.Carrier G Рєњ Type g
Generated-by G g =
  (x : Carrier) Рєњ РѕЦ (РѕЃ ╬╗ (i : Рёц) Рєњ x РЅА g ^ i) РѕЦ
  where
  open Group G

-- The property of being cyclic.

Cyclic : Group g Рєњ Type g
Cyclic G = РѕЦ РѕЃ (Generated-by G) РѕЦ

-- Cyclic groups are abelian.

CyclicРєњAbelian : (G : Group g) Рєњ Cyclic G Рєњ Abelian G
CyclicРєњAbelian G c x y =
  flip (T.rec Carrier-is-set) c          ╬╗ (g , gen-by) Рєњ
  flip (T.rec Carrier-is-set) (gen-by x) ╬╗ (i , xРЅА) Рєњ
  flip (T.rec Carrier-is-set) (gen-by y) ╬╗ (j , yРЅА) Рєњ
    x Рѕў y          РЅАРЪе congРѓѓ _Рѕў_ xРЅА yРЅА РЪЕ
    g ^ i Рѕў g ^ j  РЅАРЪе ^Рѕў^ i РЪЕ
    g ^ (i + j)    РЅАРЪе cong (g ^_) $ +-comm i РЪЕ
    g ^ (j + i)    РЅАРЪе sym $ ^Рѕў^ j РЪЕ
    g ^ j Рѕў g ^ i  РЅАРЪе sym $ congРѓѓ _Рѕў_ yРЅА xРЅА РЪЕРѕј
    y Рѕў x          Рѕј
  where
  open Group G

-- If two groups are isomorphic, and one is generated by g, then the
-- other is generated by the image of g under the isomorphism.

РЅЃр┤│РєњGenerated-byРєњGenerated-by :
  (GРѓЂРЅЃGРѓѓ : GРѓЂ РЅЃр┤│ GРѓѓ) Рєњ
  Generated-by GРѓЂ g Рєњ
  Generated-by GРѓѓ (to GРѓЂРЅЃGРѓѓ g)
РЅЃр┤│РєњGenerated-byРєњGenerated-by {GРѓЂ} {GРѓѓ} {g} GРѓЂРЅЃGРѓѓ gen-by x =
  flip T.РѕЦРѕЦ-map (gen-by (_РЅЃ_.from (GРѓЂРЅЃGРѓѓ .related) x)) ╬╗ (i , xРЅА) Рєњ
    i
  , (x                    РЅАРЪе sym $ _РЅЃ_.from-to (GРѓЂРЅЃGРѓѓ .related) xРЅА РЪЕ
     to GРѓЂРЅЃGРѓѓ (g GРѓЂ.^ i)  РЅАРЪе G.Рєњр┤│-^ GРѓЂРЅЃGРѓѓ g i РЪЕРѕј
     to GРѓЂРЅЃGРѓѓ g GРѓѓ.^ i    Рѕј)
  where
  module GРѓЂ = Group GРѓЂ
  module GРѓѓ = Group GРѓѓ

-- If two groups are isomorphic, and one is cyclic, then the other one
-- is cyclic.

РЅЃр┤│РєњCyclicРєњCyclic : GРѓЂ РЅЃр┤│ GРѓѓ Рєњ Cyclic GРѓЂ Рєњ Cyclic GРѓѓ
РЅЃр┤│РєњCyclicРєњCyclic GРѓЂРЅЃGРѓѓ =
  T.РѕЦРѕЦ-map ╬╗ (_ , gen-by) Рєњ
    _ , РЅЃр┤│РєњGenerated-byРєњGenerated-by GРѓЂРЅЃGРѓѓ gen-by

------------------------------------------------------------------------
-- The group of integers is cyclic

-- The group of integers is generated by +┬а1.

Рёц-generated-by-1 : Generated-by Рёц-group (+ 1)
Рёц-generated-by-1 i = РѕБ i , sym (*-left-identity i) РѕБ

-- The group of integers is cyclic.

Рёц-cyclic : Cyclic Рёц-group
Рёц-cyclic = РѕБ _ , Рёц-generated-by-1 РѕБ

------------------------------------------------------------------------
-- The group Рёц┬а├Ќ┬аРёц is not cyclic

-- The direct product of the group of integers and the group of
-- integers is not cyclic.

Рёц├ЌРёц-not-cyclic : ┬г Cyclic (Рёц-group G.├Ќ Рёц-group)
Рёц├ЌРёц-not-cyclic =
  T.rec РіЦ-propositional ╬╗ (g , gen-by) Рєњ
  flip (T.rec РіЦ-propositional) (gen-by (+ 0 , + 1)) ╬╗ (i , 0,1РЅА) Рєњ
  flip (T.rec РіЦ-propositional) (gen-by (+ 1 , + 0)) ╬╗ (j , 1,0РЅА) Рєњ
  lemmaРѓѓ g i j (0,1РЅА , 1,0РЅА)
  where
  module G┬▓ = Group (Рёц-group G.├Ќ Рёц-group)

  0РЅА*+РєњРЅА0 : Рѕђ n i Рєњ + 0 РЅА i *+ P.suc n Рєњ i РЅА + 0
  0РЅА*+РєњРЅА0 n i 0РЅА = case -Ріј0Ріј+ i of ╬╗ where
    (injРѓЂ neg)        Рєњ РіЦ-elim $ ┬г-0 (<0Рєњ*+suc<0 i n neg) (sym 0РЅА)
    (injРѓѓ (injРѓЂ РЅА0))  Рєњ РЅА0
    (injРѓѓ (injРѓѓ pos)) Рєњ РіЦ-elim $ ┬г+0 (>0Рєњ*+suc> i n pos) (sym 0РЅА)

  1РЅб0* : Рѕђ i Рєњ + 1 РЅб + 0 РіЏ i
  1РЅб0* i =
    + 1 РЅА + 0 РіЏ i  РєЮРЪе flip trans (РёцG.id^ i) РЪЕ
    + 1 РЅА + 0      РєЮРЪе +[1+]РЅб- РЪЕРќА
    РіЦ              РќА

  -РЅА0РєњРЅА0 : - i РЅА + 0 Рєњ i РЅА + 0
  -РЅА0РєњРЅА0 {i} hyp =
    i      РЅАРЪе sym $ РёцG.involutive _ РЪЕ
    - - i  РЅАРЪе cong -_ hyp РЪЕ
    - + 0  РЅАРЪе РёцG.identity РЪЕРѕј
    + 0    Рѕј

  lemmaРѓЂ :
    Рѕђ gРѓЂ gРѓѓ i j Рєњ
    ┬г ((+ 0 РЅА gРѓЂ РіЏ i ├Ќ + 1 РЅА gРѓѓ РіЏ i) ├Ќ
       (+ 1 РЅА gРѓЂ РіЏ j ├Ќ + 0 РЅА gРѓѓ РіЏ j))
  lemmaРѓЂ _ _ (+ zero) _ =
    (_ ├Ќ + 1 РЅА + 0) ├Ќ _  РєЮРЪе projРѓѓ Ріџ projРѓЂ РЪЕ
    + 1 РЅА + 0            РєЮРЪе +[1+]РЅб- РЪЕРќА
    РіЦ                    РќА

  lemmaРѓЂ gРѓЂ gРѓѓ (+ P.suc m) j =
    (+ 0 РЅА gРѓЂ *+ P.suc m ├Ќ _) ├Ќ (+ 1 РЅА gРѓЂ РіЏ j ├Ќ _)  РєЮРЪе ╬Б-map (0РЅА*+РєњРЅА0 m _ Ріџ projРѓЂ) projРѓЂ РЪЕ
    gРѓЂ РЅА + 0 ├Ќ + 1 РЅА gРѓЂ РіЏ j                         РєЮРЪе (╬╗ (p , q) Рєњ trans q (cong (_РіЏ j) p)) РЪЕ
    + 1 РЅА (+ 0) РіЏ j                                 РєЮРЪе 1РЅб0* j РЪЕРќА
    РіЦ                                               РќА

  lemmaРѓЂ gРѓЂ gРѓѓ -[1+ m ] j =
    (+ 0 РЅА (- gРѓЂ) *+ P.suc m ├Ќ _) ├Ќ (+ 1 РЅА gРѓЂ РіЏ j ├Ќ _)  РєЮРЪе ╬Б-map (0РЅА*+РєњРЅА0 m _ Ріџ projРѓЂ) projРѓЂ РЪЕ
    - gРѓЂ РЅА + 0 ├Ќ + 1 РЅА gРѓЂ РіЏ j                           РєЮРЪе ╬Б-map -РЅА0РєњРЅА0 P.id РЪЕ
    gРѓЂ РЅА + 0 ├Ќ + 1 РЅА gРѓЂ РіЏ j                             РєЮРЪе (╬╗ (p , q) Рєњ trans q (cong (_РіЏ j) p)) РЪЕ
    + 1 РЅА (+ 0) РіЏ j                                     РєЮРЪе 1РЅб0* j РЪЕРќА
    РіЦ                                                   РќА

  lemmaРѓѓ : Рѕђ g i j Рєњ ┬г ((+ 0 , + 1) РЅА g G┬▓.^ i ├Ќ (+ 1 , + 0) РЅА g G┬▓.^ j)
  lemmaРѓѓ g@(gРѓЂ , gРѓѓ) i j =
    (+ 0 , + 1) РЅА g G┬▓.^ i ├Ќ (+ 1 , + 0) РЅА g G┬▓.^ j  РєЮРЪе ╬Б-map (flip trans (G.^-├Ќ Рёц-group Рёц-group i))
                                                              (flip trans (G.^-├Ќ Рёц-group Рёц-group j)) РЪЕ
    (+ 0 , + 1) РЅА (gРѓЂ РіЏ i , gРѓѓ РіЏ i) ├Ќ
    (+ 1 , + 0) РЅА (gРѓЂ РіЏ j , gРѓѓ РіЏ j)                  РєћРЪе inverse $ РЅА├ЌРЅАРєћРЅА ├Ќ-cong РЅА├ЌРЅАРєћРЅА РЪЕ

    (+ 0 РЅА gРѓЂ РіЏ i ├Ќ + 1 РЅА gРѓѓ РіЏ i) ├Ќ
    (+ 1 РЅА gРѓЂ РіЏ j ├Ќ + 0 РЅА gРѓѓ РіЏ j)                    РєЮРЪе lemmaРѓЂ gРѓЂ gРѓѓ i j РЪЕРќА

    РіЦ                                                РќА

-- The group of integers is not isomorphic to the direct product of
-- the group of integers and the group of integers.

РёцРЅёр┤│Рёц├ЌРёц : ┬г Рёц-group РЅЃр┤│ (Рёц-group G.├Ќ Рёц-group)
РёцРЅёр┤│Рёц├ЌРёц =
  Рёц-group РЅЃр┤│ (Рёц-group G.├Ќ Рёц-group)  РєЮРЪе flip РЅЃр┤│РєњCyclicРєњCyclic Рёц-cyclic РЪЕ
  Cyclic (Рёц-group G.├Ќ Рёц-group)      РєЮРЪе Рёц├ЌРёц-not-cyclic РЪЕРќА
  РіЦ                                 РќА

-- The group of integers is not equal to the direct product of the
-- group of integers and the group of integers.

РёцРЅбРёц├ЌРёц : Рёц-group РЅб (Рёц-group G.├Ќ Рёц-group)
РёцРЅбРёц├ЌРёц =
  Рёц-group РЅА (Рёц-group G.├Ќ Рёц-group)   РєЮРЪе flip (subst (Рёц-group РЅЃр┤│_)) G.РєЮр┤│-refl РЪЕ
  Рёц-group РЅЃр┤│ (Рёц-group G.├Ќ Рёц-group)  РєЮРЪе РёцРЅёр┤│Рёц├ЌРёц РЪЕРќА
  РіЦ                                 РќА

------------------------------------------------------------------------
-- The "equality modulo n" relation

-- Equality modulo n.

infix 4 _РЅА_mod_

_РЅА_mod_ : Рёц Рєњ Рёц Рєњ РёЋ Рєњ Type
i РЅА j mod n = РѕЦ (РѕЃ ╬╗ k Рєњ i РЅА j + k *+ n) РѕЦ

-- The relation _РЅА_mod┬аn is an equivalence relation.

РЅА-mod-is-equivalence-relation :
  Рѕђ n Рєњ Is-equivalence-relation (_РЅА_mod n)
РЅА-mod-is-equivalence-relation n = ╬╗ where
  .Is-equivalence-relation.reflexive {x = i} Рєњ
    РѕБ + 0
    , (i             РЅАРЪе sym +-right-identity РЪЕ
       i + + 0       РЅАРЪе cong (_+_ i) $ sym $ РёцG.id^+ n РЪЕРѕј
       i + + 0 *+ n  Рѕј)
    РѕБ
  .Is-equivalence-relation.symmetric {x = i} {y = j} Рєњ
    T.РѕЦРѕЦ-map ╬╗ (k , iРЅАj+kn) Рєњ
        - k
      , (j                        РЅАРЪе sym +-right-identity РЪЕ
         j + + 0                  РЅАРЪе cong (_+_ j) $ sym $ +-right-inverse (k *+ n) РЪЕ
         j + (k *+ n - k *+ n)    РЅАРЪе cong (_+_ j) $ cong (_+_ (k *+ n)) $ РёцG.^+РЂ╗┬╣ n РЪЕ
         j + (k *+ n + - k *+ n)  РЅАРЪе +-assoc j РЪЕ
         j + k *+ n + - k *+ n    РЅАРЪе cong (_+ - k *+ n) $ sym iРЅАj+kn РЪЕРѕј
         i + - k *+ n             Рѕј)

  .Is-equivalence-relation.transitive {x = i} {y = j} {z = k} Рєњ
    T.rec (╬а-closure ext 1 ╬╗ _ Рєњ
           T.truncation-is-proposition) ╬╗ (lРѓЂ , iРЅАj+lРѓЂn) Рєњ
    T.РѕЦРѕЦ-map ╬╗ (lРѓѓ , jРЅАk+lРѓѓn) Рєњ
        lРѓѓ + lРѓЂ
      , (i                        РЅАРЪе iРЅАj+lРѓЂn РЪЕ
         j + lРѓЂ *+ n              РЅАРЪе cong (_+ lРѓЂ *+ n) jРЅАk+lРѓѓn РЪЕ
         k + lРѓѓ *+ n + lРѓЂ *+ n    РЅАРЪе sym $ +-assoc k РЪЕ
         k + (lРѓѓ *+ n + lРѓЂ *+ n)  РЅАРЪе cong (_+_ k) $ sym $ *+-distrib-+ n РЪЕРѕј
         k + (lРѓѓ + lРѓЂ) *+ n       Рѕј)

-- If i and j are equal modulo n, then i┬а+┬аk and j┬а+┬аk are also equal
-- modulo n.

+-cong : Рѕђ n j Рєњ i РЅА j mod n Рєњ i + k РЅА j + k mod n
+-cong {i} {k} n j = T.РѕЦРѕЦ-map ╬╗ (l , iРЅАj+ln) Рєњ
    l
  , (i + k             РЅАРЪе cong (_+ k) iРЅАj+ln РЪЕ
     j + l *+ n + k    РЅАРЪе sym $ +-assoc j РЪЕ
     j + (l *+ n + k)  РЅАРЪе cong (_+_ j) $ +-comm (l *+ n) РЪЕ
     j + (k + l *+ n)  РЅАРЪе +-assoc j РЪЕРѕј
     j + k + l *+ n    Рѕј)

-- If i and j are equal modulo n, then -┬аi and -┬аj are also equal
-- modulo n.

negate-cong : Рѕђ n j Рєњ i РЅА j mod n Рєњ - i РЅА - j mod n
negate-cong {i} n j = T.РѕЦРѕЦ-map ╬╗ (k , iРЅАj+kn) Рєњ
    - k
  , (- i               РЅАРЪе cong -_ iРЅАj+kn РЪЕ
     - (j + k *+ n)    РЅАРЪе РёцG.РѕўРЂ╗┬╣ {p = j} РЪЕ
     - (k *+ n) + - j  РЅАРЪе +-comm (- (k *+ n)) РЪЕ
     - j + - (k *+ n)  РЅАРЪе cong (_+_ (- j)) $ РёцG.^+РЂ╗┬╣ n РЪЕРѕј
     - j + - k *+ n    Рѕј)

-- If i and j are equal modulo n, then i┬а*+┬аm and j┬а*+┬аm are equal
-- modulo m┬а*┬аn.

*+-cong : Рѕђ m Рєњ i РЅА j mod n Рєњ i *+ m РЅА j *+ m mod m * n
*+-cong {i} {j} {n} m = T.РѕЦРѕЦ-map ╬╗ (k , iРЅАj+kn) Рєњ
    k
  , (i *+ m                 РЅАРЪе cong (_*+ m) iРЅАj+kn РЪЕ
     (j + k *+ n) *+ m      РЅАРЪе РёцG.Рѕў^+РЅА^+Рѕў^+ (+-comm j) m РЪЕ
     j *+ m + k *+ n *+ m   РЅАРЪе cong (_+_ (j *+ m)) $ РёцG.^+^+РЅА^+* n РЪЕ
     j *+ m + k *+ (n * m)  РЅАРЪе cong (_+_ (j *+ m)) $ cong (k *+_) $ Nat.*-comm n РЪЕРѕј
     j *+ m + k *+ (m * n)  Рѕј)

-- If i and j are equal modulo 2┬а*┬аn, then Рїі┬аi┬а/2РїІ and Рїі┬аj┬а/2РїІ are
-- equal modulo n.

Рїі/2РїІ-cong : Рѕђ j n Рєњ i РЅА j mod 2 * n Рєњ Рїі i /2РїІ РЅА Рїі j /2РїІ mod n
Рїі/2РїІ-cong {i} j n = T.РѕЦРѕЦ-map ╬╗ (k , iРЅАj+k2n) Рєњ
    k
  , (Рїі i /2РїІ                  РЅАРЪе cong Рїі_/2РїІ iРЅАj+k2n РЪЕ
     Рїі j + k *+ (2 * n) /2РїІ   РЅАРЪе cong (Рїі_/2РїІ Ріџ (_+_ j) Ріџ (k *+_)) $ sym $ Nat.*-comm n РЪЕ
     Рїі j + k *+ (n * 2) /2РїІ   РЅАРЪе cong (Рїі_/2РїІ Ріџ (_+_ j)) $ sym $ РёцG.^+^+РЅА^+* n РЪЕ
     Рїі j + (k *+ n) *+ 2 /2РїІ  РЅАРЪе Рїі+*+2/2РїІРЅА j РЪЕРѕј
     Рїі j /2РїІ + k *+ n         Рѕј)

-- It is not the case that 0 is equal to 1 modulo n, if n is at least
-- 2.

0РЅб1mod2+ : Рѕђ n Рєњ ┬г + 0 РЅА + 1 mod 2 РіЋ n
0РЅб1mod2+ n = T.rec РіЦ-propositional $ uncurry lemma
  where
  lemma : Рѕђ k Рєњ + 0 РЅб + 1 + k *+ (2 РіЋ n)
  lemma (+ 0) =
    + 0 РЅА + 1 + + 0 *+ (2 РіЋ n)  РєЮРЪе flip trans (cong (_+_ (+ 1)) $ РёцG.id^+ (2 РіЋ n)) РЪЕ
    + 0 РЅА + 1 + + 0             РєћРЪеРЪЕ
    + 0 РЅА + 1                   РєЮРЪе +[1+]РЅб- Ріџ sym РЪЕРќА
    РіЦ                           РќА
  lemma (+ suc k) =
    + 0 РЅА + 1 + + suc k *+ (2 РіЋ n)         РєЮРЪе flip ┬г+0 Ріџ sym РЪЕ
    ┬г Positive (+ 1 + + suc k *+ (2 РіЋ n))  РєЮРЪе _Ріџ >0Рєњ>0Рєњ+>0 (+ 1) (+ suc k *+ (2 РіЋ n)) _ РЪЕ
    ┬г Positive (+ suc k *+ (2 РіЋ n))        РєЮРЪе _$ >0Рєњ*+suc> (+ suc k) (suc n) _ РЪЕРќА
    РіЦ                                      РќА
  lemma -[1+ zero ] =
    + 0 РЅА + 1 + -[1+ 0 ] *+ (2 РіЋ n)             РєЮРЪе flip trans (+-assoc (+ 1) {j = -[1+ 0 ]} {k = -[1+ 0 ] *+ (1 РіЋ n)}) РЪЕ
    + 0 РЅА + 1 + -[1+ 0 ] + -[1+ 0 ] *+ (1 РіЋ n)  РєЮРЪе flip trans +-left-identity РЪЕ
    + 0 РЅА -[1+ 0 ] *+ (1 РіЋ n)                   РєЮРЪе flip ┬г-0 Ріџ sym РЪЕ
    ┬г Negative (-[1+ 0 ] *+ (1 РіЋ n))            РєЮРЪе _$ <0Рєњ*+suc<0 -[1+ 0 ] n _ РЪЕРќА
    РіЦ                                           РќА
  lemma -[1+ suc k ] =
    + 0 РЅА + 1 + -[1+ suc k ] *+ (2 РіЋ n)                 РєЮРЪе flip trans (+-assoc (+ 1) {j = -[1+ suc k ]} {k = -[1+ suc k ] *+ (1 РіЋ n)}) РЪЕ
    + 0 РЅА + 1 + -[1+ suc k ] + -[1+ suc k ] *+ (1 РіЋ n)  РєћРЪеРЪЕ
    + 0 РЅА -[1+ k ] + -[1+ suc k ] *+ (1 РіЋ n)            РєЮРЪе flip ┬г-0 Ріџ sym РЪЕ
    ┬г Negative (-[1+ k ] + -[1+ suc k ] *+ (1 РіЋ n))     РєЮРЪе _Ріџ <0Рєњ<0Рєњ+<0 -[1+ k ] (-[1+ suc k ] *+ (1 РіЋ n)) _ РЪЕ
    ┬г Negative (-[1+ suc k ] *+ (1 РіЋ n))                РєЮРЪе _$ <0Рєњ*+suc<0 -[1+ suc k ] n _ РЪЕРќА
    РіЦ                                                   РќА

-- It is not the case that Рїі_/2РїІ distributes over _+_ modulo 2┬аРіЋ┬аn
-- (for any n).

┬гРїі+/2РїІРЅАРїі/2РїІ+Рїі/2РїІmod2+ :
  ┬г (Рѕђ i j Рєњ Рїі i + j /2РїІ РЅА Рїі i /2РїІ + Рїі j /2РїІ mod 2 РіЋ n)
┬гРїі+/2РїІРЅАРїі/2РїІ+Рїі/2РїІmod2+ {n} =
  (Рѕђ i j Рєњ Рїі i + j /2РїІ РЅА Рїі i /2РїІ + Рїі j /2РїІ mod 2 РіЋ n)  РєЮРЪе (_$ (+ 1)) Ріџ (_$ (+ 1)) РЪЕ
  + 1 РЅА + 0 mod 2 РіЋ n                                  РєЮРЪе РЅА-mod-is-equivalence-relation (2 РіЋ n)
                                                            .Is-equivalence-relation.symmetric РЪЕ
  + 0 РЅА + 1 mod 2 РіЋ n                                  РєЮРЪе 0РЅб1mod2+ n РЪЕРќА
  РіЦ                                                    РќА

