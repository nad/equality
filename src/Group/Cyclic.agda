-- Finite cyclic groups

-- Рёц/[1+┬аn┬а]Рёц is the group of integers with addition modulo 1┬а+┬аn (the
-- finite cyclic group of order 1┬а+┬аn).

Рёц/[1+_]Рёц : РёЋ Рєњ Group lzero
Рёц/[1+ n ]Рёц = ╬╗ where
    .Group.Carrier        Рєњ Рёц / (_РЅА_mod suc n)
    .Group.Carrier-is-set Рєњ Q./-is-set
    .Group._Рѕў_            Рєњ _+Рђ▓_
    .Group.id             Рєњ Q.[ + 0 ]
    .Group._РЂ╗┬╣            Рєњ -Рђ▓_
    .Group.left-identity  Рєњ left-identity
    .Group.right-identity Рєњ right-identity
    .Group.assoc          Рєњ assoc
    .Group.left-inverse   Рєњ left-inverse
    .Group.right-inverse  Рєњ right-inverse
  where
  _+Рђ▓_ : Рёц / (_РЅА_mod suc n) Рєњ Рёц / (_РЅА_mod suc n) Рєњ Рёц / (_РЅА_mod suc n)
  _+Рђ▓_ = Q.rec ╬╗ where
    .Q.[]╩│ i Рєњ _+_ i Q./-map ╬╗ jРѓЂ jРѓѓ Рєњ
      jРѓЂ РЅА jРѓѓ mod suc n            РєЮРЪе +-cong (suc n) jРѓѓ РЪЕ
      jРѓЂ + i РЅА jРѓѓ + i mod suc n    РєЮРЪе РЅАРЄњРєЮ _ $ congРѓѓ (_РЅА_mod suc n) (+-comm jРѓЂ) (+-comm jРѓѓ) РЪЕРќА
      i + jРѓЂ РЅА i + jРѓѓ mod suc n    РќА
    .Q.is-set╩│ Рєњ
      ╬а-closure ext 2 ╬╗ _ Рєњ
      Q./-is-set
    .Q.[]-respects-relation╩│ {x = iРѓЂ} {y = iРѓѓ} iРѓЂРЅАiРѓѓ Рєњ
      РЪеextРЪЕ $ Q.elim-prop ╬╗ where
        .Q.is-proposition╩│ _ Рєњ Q./-is-set
        .Q.[]╩│ j             Рєњ         $РЪе iРѓЂРЅАiРѓѓ РЪЕ
          iРѓЂ РЅА iРѓѓ mod suc n            РєЮРЪе +-cong (suc n) iРѓѓ РЪЕ
          iРѓЂ + j РЅА iРѓѓ + j mod suc n    РєЮРЪе Q.[]-respects-relation РЪЕРќА
          Q.[ iРѓЂ + j ] РЅА Q.[ iРѓѓ + j ]  РќА

  -Рђ▓_ : Рёц / (_РЅА_mod suc n) Рєњ Рёц / (_РЅА_mod suc n)
  -Рђ▓_ = -_ Q./-map ╬╗ iРѓЂ iРѓѓ Рєњ
    iРѓЂ РЅА iРѓѓ mod suc n      РєЮРЪе negate-cong (suc n) iРѓѓ РЪЕРќА
    - iРѓЂ РЅА - iРѓѓ mod suc n  РќА

  left-identity : Рѕђ i Рєњ Q.[ + 0 ] +Рђ▓ i РЅА i
  left-identity = Q.elim-prop ╬╗ where
    .Q.is-proposition╩│ _ Рєњ Q./-is-set
    .Q.[]╩│ _             Рєњ cong Q.[_] +-left-identity

  right-identity : Рѕђ i Рєњ i +Рђ▓ Q.[ + 0 ] РЅА i
  right-identity = Q.elim-prop ╬╗ where
    .Q.is-proposition╩│ _ Рєњ Q./-is-set
    .Q.[]╩│ _             Рєњ cong Q.[_] +-right-identity

  assoc : Рѕђ i j k Рєњ (i +Рђ▓ (j +Рђ▓ k)) РЅА ((i +Рђ▓ j) +Рђ▓ k)
  assoc = Q.elim-prop ╬╗ where
    .Q.is-proposition╩│ _ Рєњ ╬а-closure ext 1 ╬╗ _ Рєњ
                           ╬а-closure ext 1 ╬╗ _ Рєњ
                           Q./-is-set
    .Q.[]╩│ i             Рєњ Q.elim-prop ╬╗ where
      .Q.is-proposition╩│ _ Рєњ ╬а-closure ext 1 ╬╗ _ Рєњ
                             Q./-is-set
      .Q.[]╩│ _             Рєњ Q.elim-prop ╬╗ where
        .Q.is-proposition╩│ _ Рєњ Q./-is-set
        .Q.[]╩│ _             Рєњ cong Q.[_] $ +-assoc i

  left-inverse : Рѕђ i Рєњ ((-Рђ▓ i) +Рђ▓ i) РЅА Q.[ + 0 ]
  left-inverse = Q.elim-prop ╬╗ where
    .Q.is-proposition╩│ _ Рєњ Q./-is-set
    .Q.[]╩│ i             Рєњ cong Q.[_] $ +-left-inverse i

  right-inverse : Рѕђ i Рєњ (i +Рђ▓ (-Рђ▓ i)) РЅА Q.[ + 0 ]
  right-inverse = Q.elim-prop ╬╗ where
    .Q.is-proposition╩│ _ Рєњ Q./-is-set
    .Q.[]╩│ i             Рєњ cong Q.[_] $ +-right-inverse i

-- Рёц/[1+┬аn┬а]Рёц is cyclic.

Рёц/Рёц-cyclic : Cyclic Рёц/[1+ n ]Рёц
Рёц/Рёц-cyclic {n} =
  РѕБ Q.[ + 1 ]
  , (Q.elim-prop ╬╗ where
       .Q.is-proposition╩│ _ Рєњ T.truncation-is-proposition
       .Q.[]╩│ i             Рєњ
         РѕБ i
         , (Q.[ i ]           РЅАРЪе cong Q.[_] $ sym $ *-left-identity i РЪЕ
            Q.[ + 1 РіЏ i ]     РЅАРЪе lemma i РЪЕРѕј
            Q.[ + 1 ] Рёц/.^ i  Рѕј)
         РѕБ)
  РѕБ
  where
  module Рёц/ = Group Рёц/[1+ n ]Рёц

  *+-lemma : Рѕђ n Рєњ Q.[ + 1 *+ n ] РЅА Q.[ + 1 ] Рёц/.^+ n
  *+-lemma zero    = refl _
  *+-lemma (suc n) =
    Q.[ + 1 *+ suc n ]                РЅАРЪеРЪЕ
    Q.[ + 1 ] Рёц/.Рѕў Q.[ + 1 *+ n ]     РЅАРЪе cong (Q.[ + 1 ] Рёц/.Рѕў_) $ *+-lemma n РЪЕРѕј
    Q.[ + 1 ] Рёц/.Рѕў Q.[ + 1 ] Рёц/.^+ n  Рѕј

  lemma : Рѕђ i Рєњ Q.[ + 1 РіЏ i ] РЅА Q.[ + 1 ] Рёц/.^ i
  lemma (+ n)    = *+-lemma n
  lemma -[1+ n ] =
    Q.[ + 1 РіЏ -[1+ n ] ]           РЅАРЪеРЪЕ
    Q.[ -[ 1 ] *+ suc n ]          РЅАРЪе cong Q.[_] $ sym $ РёцG.^+РЂ╗┬╣ {p = + 1} (suc n) РЪЕ
    Q.[ - (+ 1 *+ suc n) ]         РЅАРЪеРЪЕ
    Q.[ + 1 *+ suc n ] Рёц/.РЂ╗┬╣       РЅАРЪе cong Рёц/._РЂ╗┬╣ $ *+-lemma (suc n) РЪЕ
    (Q.[ + 1 ] Рёц/.^+ suc n) Рёц/.РЂ╗┬╣  РЅАРЪе Рёц/.^+РЂ╗┬╣ {p = Q.[ + 1 ]} (suc n) РЪЕ
    (Q.[ + 1 ] Рёц/.РЂ╗┬╣) Рёц/.^+ suc n  РЅАРЪеРЪЕ
    Q.[ + 1 ] Рёц/.^ -[1+ n ]        Рѕј

-- Рёц/[1+┬аn┬а]Рёц is abelian.

Рёц/Рёц-abelian : Abelian Рёц/[1+ n ]Рёц
Рёц/Рёц-abelian = CyclicРєњAbelian Рёц/[1+ _ ]Рёц Рёц/Рёц-cyclic

-- For finite cyclic groups of order at least 2 the number 0 is not
-- equal to 1.
--
-- The proof uses propositional extensionality.

Рёц/Рёц-0РЅб1 :
  Рѕђ n Рєњ
  _РЅб_ {A = Group.Carrier Рёц/[1+ suc n ]Рёц}
    Q.[ + 0 ] Q.[ + 1 ]
Рёц/Рёц-0РЅб1 n =
  Stable-┬г
    [ Q.[ + 0 ] РЅА Q.[ + 1 ]  РєћРЪе inverse $
                                Q.relatedРЅЃ[equal]
                                  prop-ext
                                  (РЅА-mod-is-equivalence-relation (2 P.+ n))
                                  T.truncation-is-proposition РЪЕ
      (+ 0 РЅА + 1 mod 2 РіЋ n)  РєЮРЪе 0РЅб1mod2+ n РЪЕРќА
      РіЦ                      РќА
    ]

-- If any element in Рёц/2Рёц is added to itself we get 0.

private
  module Рёц/2Рёц = Group Рёц/[1+ 1 ]Рёц

Рёц/2Рёц-+РЅА0 : Рѕђ i Рєњ i Рёц/2Рёц.Рѕў i РЅА Рёц/2Рёц.id
Рёц/2Рёц-+РЅА0 = Q.elim-prop ╬╗ where
  .Q.is-proposition╩│ _ Рєњ Q./-is-set
  .Q.[]╩│ i Рєњ Q.[]-respects-relation
    РѕБ i
    , (i + i          РЅАРЪе cong (_+_ i) $ sym +-right-identity РЪЕ
       i + (i + + 0)  РЅАРЪеРЪЕ
       i *+ 2         РЅАРЪе sym +-left-identity РЪЕРѕј
       + 0 + i *+ 2   Рѕј)
    РѕБ
